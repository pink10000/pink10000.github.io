---
export interface Props {
  title: string;
  subtitle?: string;
  class?: string;
}

const { title, subtitle, class: className = '' } = Astro.props;
---

<div class={`p-6 bg-light-base00 dark:bg-dark-base00 border border-light-base02 dark:border-dark-base02 transition-colors duration-200 ${className}`}>
  <div class="flex justify-between items-center mb-6">
    <div>
      <h3 class="text-xl font-bold text-light-base05 dark:text-white transition-colors">{title}</h3>
      {subtitle && <p class="text-sm text-light-base04 dark:text-dark-base04 mt-1 transition-colors">{subtitle}</p>}
    </div>
    <slot name="actions" />
  </div>
  
  <slot />
</div>
