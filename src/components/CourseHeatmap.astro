---
import fs from 'node:fs';
import path from 'node:path';
import { getTermScore } from '../utils/termSort.js';
import ChartCard from './ChartCard.astro';
import tailwindConfig from '../../tailwind.config.mjs';

// Load and parse the CSV data server-side
const csvPath = path.resolve('./src/blog/classes.csv');
const csvContent = fs.readFileSync(csvPath, 'utf-8');

// Parse the CSV
const rows = csvContent.trim().split('\n');
const classesData = rows.slice(1).map(row => {
  let inQuotes = false;
  let currentField = '';
  const fields = [];
  
  for (let i = 0; i < row.length; i++) {
    const char = row[i];
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      fields.push(currentField);
      currentField = '';
    } else {
      currentField += char;
    }
  }
  fields.push(currentField);
  
  return {
    term: fields[0],
    subject: fields[1],
    course: fields[2],
    title: fields[3],
    units: parseFloat(fields[4]),
    usefulness: parseInt(fields[5] || '5', 10),
    enjoyment: parseInt(fields[6] || '5', 10),
    workload: parseInt(fields[7] || '5', 10),
    difficulty: parseInt(fields[8] || '5', 10),
    skipability: parseInt(fields[9] || '5', 10),
    id: `${fields[1]} ${fields[2]}`.trim(),
    uid: `${fields[0]}-${fields[1]}-${fields[2]}`.trim()
  };
});

// Academic Year Sorting Logic (Summer -> Fall -> Winter -> Spring)
classesData.sort((a, b) => {
  const scoreA = getTermScore(a.term);
  const scoreB = getTermScore(b.term);
  
  if (scoreA !== scoreB) {
    return scoreA - scoreB;
  }
  // Alphabetical tiebreaker
  return a.id.localeCompare(b.id, undefined, { numeric: true });
});

const darkColors = tailwindConfig.theme.extend.colors.dark;
const lightColors = tailwindConfig.theme.extend.colors.light;
---

<course-heatmap data-classes={JSON.stringify(classesData)} data-dark={JSON.stringify(darkColors)} data-light={JSON.stringify(lightColors)} class="block w-full">
  <ChartCard title="Course Ratings Matrix" subtitle="Rendered natively with D3.js. Grouped chronologically." collapsible={true}>
    <div class="relative overflow-x-auto custom-scrollbar pb-2 flex justify-center">
      
      <!-- Tooltip -->
      <div id="heatmap-tooltip" class="absolute pointer-events-none opacity-0 bg-light-base00 dark:bg-dark-base00 border border-light-base03 dark:border-dark-base03 p-3 shadow-xl z-50 transition-opacity duration-200 text-left"></div>
      
      <!-- SVG Container -->
      <div id="heatmap-container"></div>
      
    </div>
  </ChartCard>
</course-heatmap>

<script>
  import * as d3 from 'd3';

  class CourseHeatmap extends HTMLElement {
    connectedCallback() {
      // Delay initialization slightly to ensure canvas elements are parsed
      requestAnimationFrame(() => {
        this.initHeatmap();
      });

      // Watch for theme changes to re-render chart colors
      const observer = new MutationObserver(() => this.initHeatmap());
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    }

    initHeatmap() {
      const data = JSON.parse(this.dataset.classes);
      const darkColors = JSON.parse(this.dataset.dark);
      const lightColors = JSON.parse(this.dataset.light);
      const container = d3.select(this.querySelector('#heatmap-container'));
      const tooltip = d3.select(this).select('#heatmap-tooltip');
      
      // Clear previous SVG
      container.selectAll('*').remove();

      // Theme Colors
      const isDark = document.documentElement.classList.contains('dark');
      const theme = isDark ? darkColors : lightColors;
      
      const textColor = isDark ? theme.base04 : theme.base02; 
      const axisLineColor = theme.base03; 
      const hoverBorderColor = isDark ? theme.base06 : theme.base03;
      
      // Oxocarbon Heatmap Colors
      const colorLow = isDark ? theme.base01 : theme.base00;
      const colorHigh = theme.base0E;

      // Constants
      const SLOT_HEIGHT = 28;
      const GAP_HEIGHT = SLOT_HEIGHT / 4; // ~7px gap between quarters

      // --- CUSTOM LAYOUT ALGORITHM ---
      let currentY = 0;
      let lastTerm = null;
      const coursePositions = {};
      const quarterGroups = [];
      let currentQuarter = null;

      data.forEach((cls) => {
        if (cls.term !== lastTerm) {
          if (lastTerm !== null) {
            currentY += GAP_HEIGHT; // Inject vertical gap
            // Close out the previous quarter tracking
            if (currentQuarter) {
              currentQuarter.endY = currentY - GAP_HEIGHT;
              quarterGroups.push(currentQuarter);
            }
          }
          currentQuarter = { term: cls.term, startY: currentY };
          lastTerm = cls.term;
        }
        coursePositions[cls.uid] = currentY;
        currentY += SLOT_HEIGHT;
      });
      // Close the final quarter tracking
      if (currentQuarter) {
        currentQuarter.endY = currentY;
        quarterGroups.push(currentQuarter);
      }

      const totalHeight = currentY;

      // Flatten data for matrix processing
      const matrixData = [];
      data.forEach(cls => {
        matrixData.push({ course: cls.id, uid: cls.uid, title: cls.title, term: cls.term, metric: 'Enjoyment', value: cls.enjoyment });
        matrixData.push({ course: cls.id, uid: cls.uid, title: cls.title, term: cls.term, metric: 'Usefulness', value: cls.usefulness });
        matrixData.push({ course: cls.id, uid: cls.uid, title: cls.title, term: cls.term, metric: 'Workload', value: cls.workload });
        matrixData.push({ course: cls.id, uid: cls.uid, title: cls.title, term: cls.term, metric: 'Difficulty', value: cls.difficulty });
        matrixData.push({ course: cls.id, uid: cls.uid, title: cls.title, term: cls.term, metric: 'Skipability', value: cls.skipability });
      });

      const metrics = ['Enjoyment', 'Usefulness', 'Workload', 'Difficulty', 'Skipability'];

      // SVG Dimensions
      const margin = { top: 40, right: 30, bottom: 20, left: 130 }; // Increased left margin for brackets
      const width = 550 - margin.left - margin.right;
      const height = totalHeight;

      const svg = container.append('svg')
        .attr('width', width + margin.left + margin.right)
        .attr('height', height + margin.top + margin.bottom)
        .append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      // Build X scales and axis (Standard scaleBand)
      const x = d3.scaleBand()
        .range([0, width])
        .domain(metrics)
        .padding(0.05);

      svg.append('g')
        .attr('transform', 'translate(0,-5)')
        .call(d3.axisTop(x).tickSize(0))
        .select('.domain').remove();
        
      svg.selectAll('.tick text')
        .attr('fill', textColor)
        .style('font-size', '10px')
        .style('font-weight', 'bold')
        .style('text-transform', 'uppercase');

      // Draw Course Labels (Custom Y-Axis Replacement)
      svg.selectAll('.course-label')
        .data(data)
        .enter()
        .append('text')
        .attr('class', 'course-label')
        .attr('x', -10)
        .attr('y', d => coursePositions[d.uid] + (SLOT_HEIGHT / 2))
        .attr('dy', '0.32em')
        .attr('text-anchor', 'end')
        .style('font-family', 'monospace')
        .style('font-size', '12px')
        .style('font-weight', 'bold')
        .style('fill', textColor)
        .text(d => d.id);

      // Draw Quarter Brackets and Rotated Labels
      const bracketGroup = svg.append('g').attr('class', 'brackets');
      
      quarterGroups.forEach(group => {
        const y1 = group.startY;
        const y2 = group.endY;
        const xOffset = -85; // Distance from the left edge of the matrix blocks
        
        // Draw the bracket path `[`
        bracketGroup.append('path')
          .attr('d', `M ${xOffset + 5},${y1 + 2} L ${xOffset},${y1 + 2} L ${xOffset},${y2 - 2} L ${xOffset + 5},${y2 - 2}`)
          .style('fill', 'none')
          .style('stroke', axisLineColor)
          .style('stroke-width', 1.5);
          
        // Draw the rotated text
        bracketGroup.append('text')
          .attr('transform', `translate(${xOffset - 10}, ${(y1 + y2) / 2}) rotate(-90)`)
          .attr('text-anchor', 'middle')
          .attr('dy', '0.32em')
          .style('font-size', '10px')
          .style('font-weight', 'bold')
          .style('text-transform', 'uppercase')
          .style('fill', textColor)
          .text(group.term);
      });

      // Build OKLCH color scale using native CSS color-mix
      const getOklchColor = (value) => {
        const percent = Math.max(0, Math.min(100, value * 10)); // 0-10 maps to 0%-100%
        return `color-mix(in oklch, ${colorHigh} ${percent}%, ${colorLow})`;
      };

      // Tooltip Functions
      const mouseover = function() {
        tooltip.style('opacity', 1);
        d3.select(this)
          .style('stroke', hoverBorderColor)
          .style('stroke-width', 2);
      };

      const mousemove = function(event, d) {
        // Get mouse position relative to the container for correct absolute positioning
        const [mouseX, mouseY] = d3.pointer(event, container.node());
        
        tooltip
          .html(`
            <div class="flex justify-between items-center gap-6">
              <span class="font-bold text-light-base05 dark:text-white">${d.course}</span>
              <span class="font-bold text-light-base0E dark:text-dark-base0E">${d.value}/10</span>
            </div>
          `)
          .style('left', (mouseX + 20) + 'px')
          .style('top', (mouseY - 20) + 'px');
      };

      const mouseleave = function() {
        tooltip.style('opacity', 0);
        d3.select(this)
          .style('stroke', 'none');
      };

      // Draw Matrix Rectangles using Custom Layout Coordinates
      svg.selectAll('.matrix-cell')
        .data(matrixData)
        .enter()
        .append('rect')
        .attr('class', 'matrix-cell')
        .attr('x', d => x(d.metric))
        .attr('y', d => coursePositions[d.uid])
        .attr('width', x.bandwidth())
        .attr('height', SLOT_HEIGHT * 0.95) // Leave a tiny native gap between cells
        .style('fill', d => getOklchColor(d.value))
        .style('rx', 2)
        .style('ry', 2)
        .style('cursor', 'pointer')
        .style('transition', 'fill 0.2s')
        .on('mouseover', mouseover)
        .on('mousemove', mousemove)
        .on('mouseleave', mouseleave);

    }
  }

  // Register custom element
  if (!customElements.get('course-heatmap')) {
    customElements.define('course-heatmap', CourseHeatmap);
  }
</script>
