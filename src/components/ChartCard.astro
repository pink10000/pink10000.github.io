---
export interface Props {
  title: string;
  subtitle?: string;
  class?: string;
  collapsible?: boolean;
  defaultCollapsed?: boolean;
}

const { title, subtitle, class: className = '', collapsible = false, defaultCollapsed = true } = Astro.props;
---

<chart-card class="block w-full" data-collapsible={collapsible ? "true" : "false"} data-collapsed={defaultCollapsed ? "true" : "false"}>
  <div class={`bg-light-base00 dark:bg-dark-base00 border border-light-base02 dark:border-dark-base02 transition-colors duration-200 ${className}`}>
    
    {/* Header */}
    <div 
      class={`p-6 flex justify-between items-center select-none ${collapsible ? 'cursor-pointer hover:bg-light-base01/40 dark:hover:bg-dark-base01/40 transition-colors duration-200' : ''}`}
      data-card-header
    >
      <div>
        <h3 class="text-xl font-bold text-light-base05 dark:text-white transition-colors">{title}</h3>
        {subtitle && <p class="text-sm text-light-base04 dark:text-dark-base04 mt-1 transition-colors">{subtitle}</p>}
      </div>
      
      <div class="flex items-center gap-4">
        <slot name="actions" />
        {collapsible && (
          <button 
            type="button"
            class="p-1.5 text-light-base04 dark:text-dark-base04 hover:text-light-base05 dark:hover:text-white transition-colors focus:outline-none"
            aria-label="Toggle card body"
            data-card-chevron-btn
          >
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              class="w-5 h-5 transform transition-transform duration-300 ease-in-out" 
              data-card-chevron 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor" 
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        )}
      </div>
    </div>
    
    {/* Collapsible Content wrapper */}
    <div 
      class="collapsible-content overflow-hidden transition-all duration-300 ease-in-out" 
      data-card-content
    >
      {/* Body container with padding */}
      <div class="px-6 pb-6">
        <slot />
      </div>
    </div>
  </div>
</chart-card>

<script>
  class ChartCardComponent extends HTMLElement {
    connectedCallback() {
      const collapsible = this.getAttribute('data-collapsible') === 'true';
      if (!collapsible) return;

      const header = this.querySelector('[data-card-header]');
      const content = this.querySelector('[data-card-content]') as HTMLElement;
      const chevron = this.querySelector('[data-card-chevron]');
      
      if (!header || !content || !chevron) return;
      
      let isCollapsed = this.getAttribute('data-collapsed') === 'true';
      
      // Initialize state
      if (isCollapsed) {
        content.style.maxHeight = '0px';
        content.style.opacity = '0';
        content.style.visibility = 'hidden';
        chevron.classList.add('-rotate-90');
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        content.style.opacity = '1';
        content.style.visibility = 'visible';
      }
      
      const toggle = (e: Event) => {
        // Prevent toggle if clicking on slot="actions" interactive elements
        const target = e.target as HTMLElement;
        if (target.closest('[slot="actions"]') || target.closest('select') || target.closest('button:not([data-card-chevron-btn])') || target.closest('a')) {
          return;
        }
        
        isCollapsed = !isCollapsed;
        this.setAttribute('data-collapsed', isCollapsed ? 'true' : 'false');
        
        if (isCollapsed) {
          content.style.maxHeight = content.scrollHeight + 'px';
          // Force reflow
          content.offsetHeight;
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          chevron.classList.add('-rotate-90');
          
          const onTransitionEnd = () => {
            if (isCollapsed) {
              content.style.visibility = 'hidden';
            }
            content.removeEventListener('transitionend', onTransitionEnd);
          };
          content.addEventListener('transitionend', onTransitionEnd);
        } else {
          content.style.visibility = 'visible';
          content.style.maxHeight = '0px';
          // Force reflow
          content.offsetHeight;
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          chevron.classList.remove('-rotate-90');
          
          const onTransitionEnd = () => {
            if (!isCollapsed) {
              content.style.maxHeight = 'none';
              // Trigger resize event so Chart.js/D3 update their sizing
              window.dispatchEvent(new Event('resize'));
            }
            content.removeEventListener('transitionend', onTransitionEnd);
          };
          content.addEventListener('transitionend', onTransitionEnd);
        }
      };

      header.addEventListener('click', toggle);
    }
  }
  
  if (!customElements.get('chart-card')) {
    customElements.define('chart-card', ChartCardComponent);
  }
</script>
