---
import fs from 'node:fs';
import path from 'node:path';
import ChartCard from './ChartCard.astro';
import tailwindConfig from '../../tailwind.config.mjs';

// Load and parse the CSV data server-side
const csvPath = path.resolve('./src/blog/classes.csv');
const csvContent = fs.readFileSync(csvPath, 'utf-8');

// Parse the CSV
const rows = csvContent.trim().split('\n');
const headers = rows[0].split(',');

// Extract data, skipping header
const classesData = rows.slice(1).map(row => {
  // Simple CSV parser that handles quotes for commas
  let inQuotes = false;
  let currentField = '';
  const fields = [];
  
  for (let i = 0; i < row.length; i++) {
    const char = row[i];
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      fields.push(currentField);
      currentField = '';
    } else {
      currentField += char;
    }
  }
  fields.push(currentField);
  
  return {
    term: fields[0],
    subject: fields[1],
    course: fields[2],
    title: fields[3],
    units: parseFloat(fields[4]),
    usefulness: parseInt(fields[5] || '5', 10),
    enjoyment: parseInt(fields[6] || '5', 10),
    workload: parseInt(fields[7] || '5', 10),
    difficulty: parseInt(fields[8] || '5', 10),
    skipability: parseInt(fields[9] || '5', 10),
    id: `${fields[1]} ${fields[2]}`.trim()
  };
});
const darkColors = tailwindConfig.theme.extend.colors.dark;
const lightColors = tailwindConfig.theme.extend.colors.light;
---

<course-radar class="block w-full" data-classes={JSON.stringify(classesData)} data-dark={JSON.stringify(darkColors)} data-light={JSON.stringify(lightColors)}>
  <ChartCard title="Course Ratings (Select a Class)">
    <div class="flex flex-col md:flex-row gap-8 items-center mt-2">
      <div class="w-full md:w-1/3">
        <div class="relative">
          <select id="classSelector" class="w-full appearance-none bg-light-base01 dark:bg-dark-base01 border border-light-base02 dark:border-dark-base02 text-light-base05 dark:text-white py-3 pl-4 pr-10 rounded hover:border-light-base03 dark:hover:border-dark-base03 focus:outline-none focus:ring-1 focus:ring-light-base0E dark:focus:ring-dark-base0E transition-colors cursor-pointer text-sm font-semibold shadow-sm">
            {classesData.map(cls => (
              <option value={cls.id}>{cls.id} - {cls.title}</option>
            ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-light-base04 dark:text-dark-base04">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
          </div>
        </div>
        <div id="classDetails" class="mt-8 text-light-base04 dark:text-dark-base04 space-y-3 transition-colors bg-light-base01 dark:bg-dark-base01 p-4 rounded border border-light-base02 dark:border-dark-base02">
          <!-- Details populated by JS -->
        </div>
      </div>
      
      <div class="relative w-full md:w-2/3 h-[400px]">
        <canvas id="radarChart"></canvas>
      </div>
    </div>
  </ChartCard>
</course-radar>

<script>
  import Chart from 'chart.js/auto';

  class CourseRadar extends HTMLElement {
    connectedCallback() {
      // Delay initialization slightly to ensure canvas elements are parsed
      requestAnimationFrame(() => {
        this.initCharts();
      });
    }

    initCharts() {
      const classesData = JSON.parse(this.dataset.classes);
      const darkColors = JSON.parse(this.dataset.dark);
      const lightColors = JSON.parse(this.dataset.light);
      
      // --- RADAR CHART ---
      const radarCtx = this.querySelector('#radarChart');
      const selector = this.querySelector('#classSelector');
      const detailsContainer = this.querySelector('#classDetails');

      if (radarCtx && selector && detailsContainer) {
        let radarChart;
        let currentClassId = classesData.length > 0 ? classesData[0].id : null;

        const updateRadarChart = (classId) => {
          if (!classId) return;
          const cls = classesData.find(c => c.id === classId);
          if (!cls) return;

          // Update Details
          detailsContainer.innerHTML = `
            <p><strong class="text-light-base05 dark:text-white">Course:</strong> ${cls.id}</p>
            <p><strong class="text-light-base05 dark:text-white">Title:</strong> ${cls.title}</p>
            <p><strong class="text-light-base05 dark:text-white">Term:</strong> ${cls.term}</p>
            <p><strong class="text-light-base05 dark:text-white">Units:</strong> ${cls.units}</p>
          `;

          const isDark = document.documentElement.classList.contains('dark');
          const theme = isDark ? darkColors : lightColors;
          
          const hexToRgba = (hex, alpha) => {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
          };
          
          // Oxocarbon Theme Accents
          const accentColor = theme.base0E; // base0E (Purple)
          const pointColor = theme.base0B; // base0B (Blue)
          const textColor = isDark ? theme.base04 : theme.base02; // base04 / base02 (Text)
          const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
          
          const radarData = {
            labels: ['Enjoyment', 'Usefulness', 'Workload', 'Difficulty', 'Skipability'],
            datasets: [{
              label: cls.id,
              data: [cls.enjoyment, cls.usefulness, cls.workload, cls.difficulty, cls.skipability],
              backgroundColor: hexToRgba(accentColor, 0.2), // Transparent accent
              borderColor: accentColor,
              pointBackgroundColor: pointColor,
              pointBorderColor: isDark ? theme.base00 : theme.base00,
              pointHoverBackgroundColor: isDark ? theme.base00 : theme.base00,
              pointHoverBorderColor: pointColor,
              borderWidth: 2,
            }]
          };

          if (radarChart) {
            radarChart.data = radarData;
            radarChart.options.scales.r.angleLines.color = gridColor;
            radarChart.options.scales.r.grid.color = gridColor;
            radarChart.options.scales.r.pointLabels.color = textColor;
            radarChart.update();
          } else {
            radarChart = new Chart(radarCtx, {
              type: 'radar',
              data: radarData,
              options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                  r: {
                    angleLines: { color: gridColor },
                    grid: { color: gridColor },
                    pointLabels: { color: textColor, font: { size: 14 } },
                    min: 0,
                    max: 10,
                    ticks: { display: false, stepSize: 2 }
                  }
                },
                plugins: {
                  legend: { display: false },
                  tooltip: {
                    backgroundColor: isDark ? 'rgba(38, 38, 38, 0.95)' : 'rgba(255, 255, 255, 0.95)',
                    titleColor: isDark ? '#ffffff' : '#161616',
                    bodyColor: isDark ? '#dde1e6' : '#525252',
                    borderColor: gridColor,
                    borderWidth: 1,
                    padding: 12
                  }
                }
              }
            });
          }
        };

        // Initialize radar
        updateRadarChart(currentClassId);

        // Handle selection change
        selector.addEventListener('change', (e) => {
          currentClassId = e.target.value;
          updateRadarChart(currentClassId);
        });

        // Watch for theme changes to re-render chart colors
        const observer = new MutationObserver(() => {
          if (currentClassId) updateRadarChart(currentClassId);
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    }
  }

  // Register custom element
  if (!customElements.get('course-radar')) {
    customElements.define('course-radar', CourseRadar);
  }
</script>
