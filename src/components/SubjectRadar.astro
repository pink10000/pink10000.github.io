---
import fs from 'node:fs';
import path from 'node:path';
import ChartCard from './ChartCard.astro';
import tailwindConfig from '../../tailwind.config.mjs';

// Load and parse the CSV data server-side
const csvPath = path.resolve('./src/blog/classes.csv');
const csvContent = fs.readFileSync(csvPath, 'utf-8');

// Parse the CSV
const rows = csvContent.trim().split('\n');
const classesData = rows.slice(1).map(row => {
  let inQuotes = false;
  let currentField = '';
  const fields = [];
  
  for (let i = 0; i < row.length; i++) {
    const char = row[i];
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      fields.push(currentField);
      currentField = '';
    } else {
      currentField += char;
    }
  }
  fields.push(currentField);
  
  return {
    subject: fields[1],
    usefulness: parseInt(fields[5] || '5', 10),
    enjoyment: parseInt(fields[6] || '5', 10),
    workload: parseInt(fields[7] || '5', 10),
    difficulty: parseInt(fields[8] || '5', 10),
    skipability: parseInt(fields[9] || '5', 10),
  };
});

const calculateAverage = (subject) => {
  const courses = classesData.filter(c => c.subject === subject);
  if (courses.length === 0) return [0, 0, 0, 0, 0];
  
  const sums = courses.reduce((acc, curr) => [
    acc[0] + curr.enjoyment,
    acc[1] + curr.usefulness,
    acc[2] + curr.workload,
    acc[3] + curr.difficulty,
    acc[4] + curr.skipability
  ], [0, 0, 0, 0, 0]);
  
  return sums.map(sum => Number((sum / courses.length).toFixed(2)));
};

const cseAverages = calculateAverage('CSE');
const mathAverages = calculateAverage('MATH');

const chartData = {
  cse: cseAverages,
  math: mathAverages
};

const darkColors = tailwindConfig.theme.extend.colors.dark;
const lightColors = tailwindConfig.theme.extend.colors.light;
---

<subject-radar class="block w-full" data-averages={JSON.stringify(chartData)} data-dark={JSON.stringify(darkColors)} data-light={JSON.stringify(lightColors)}>
  <ChartCard title="Department Comparison: CSE vs MATH" subtitle="Average ratings across all computer science and mathematics courses.">
    <div class="relative w-full aspect-square max-h-[350px] mx-auto flex justify-center items-center">
      <canvas id="subjectRadarChart"></canvas>
    </div>
  </ChartCard>
</subject-radar>

<script>
  import Chart from 'chart.js/auto';

  class SubjectRadar extends HTMLElement {
    connectedCallback() {
      requestAnimationFrame(() => {
        this.initCharts();
      });
    }

    initCharts() {
      const averages = JSON.parse(this.dataset.averages);
      const darkColors = JSON.parse(this.dataset.dark);
      const lightColors = JSON.parse(this.dataset.light);
      const radarCtx = this.querySelector('#subjectRadarChart');

      if (radarCtx) {
        let radarChart;

        const updateRadarChart = () => {
          const isDark = document.documentElement.classList.contains('dark');
          const theme = isDark ? darkColors : lightColors;
          
          const hexToRgba = (hex, alpha) => {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
          };
          
          // Theme Colors
          const textColor = isDark ? theme.base04 : theme.base02; 
          const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
          
          // Oxocarbon Theme Accents
          const cseColor = theme.base0B; // base0B (Blue)
          const mathColor = theme.base0A; // base0A (Pink)
          
          const radarData = {
            labels: ['Enjoyment', 'Usefulness', 'Workload', 'Difficulty', 'Skipability'],
            datasets: [
              {
                label: 'CSE',
                data: averages.cse,
                backgroundColor: hexToRgba(cseColor, 0.2),
                borderColor: cseColor,
                pointBackgroundColor: cseColor,
                pointBorderColor: isDark ? theme.base00 : theme.base00,
                pointHoverBackgroundColor: isDark ? theme.base00 : theme.base00,
                pointHoverBorderColor: cseColor,
                borderWidth: 2,
              },
              {
                label: 'MATH',
                data: averages.math,
                backgroundColor: hexToRgba(mathColor, 0.2),
                borderColor: mathColor,
                pointBackgroundColor: mathColor,
                pointBorderColor: isDark ? theme.base00 : theme.base00,
                pointHoverBackgroundColor: isDark ? theme.base00 : theme.base00,
                pointHoverBorderColor: mathColor,
                borderWidth: 2,
              }
            ]
          };

          if (radarChart) {
            radarChart.data = radarData;
            radarChart.options.scales.r.angleLines.color = gridColor;
            radarChart.options.scales.r.grid.color = gridColor;
            radarChart.options.scales.r.pointLabels.color = textColor;
            radarChart.options.plugins.legend.labels.color = textColor;
            radarChart.update();
          } else {
            radarChart = new Chart(radarCtx, {
              type: 'radar',
              data: radarData,
              options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                  r: {
                    angleLines: { color: gridColor },
                    grid: { color: gridColor },
                    pointLabels: { color: textColor, font: { size: 14, family: 'monospace' } },
                    min: 0,
                    max: 10,
                    ticks: { display: false, stepSize: 2 }
                  }
                },
                plugins: {
                  legend: { 
                    position: 'top',
                    labels: { color: textColor, font: { size: 14, family: 'monospace' }, usePointStyle: true }
                  },
                  tooltip: {
                    backgroundColor: isDark ? 'rgba(38, 38, 38, 0.95)' : 'rgba(255, 255, 255, 0.95)',
                    titleColor: isDark ? '#ffffff' : '#161616',
                    bodyColor: isDark ? '#dde1e6' : '#525252',
                    titleFont: { family: 'monospace' },
                    bodyFont: { family: 'monospace' },
                    borderColor: gridColor,
                    borderWidth: 1,
                    padding: 12
                  }
                }
              }
            });
          }
        };

        // Initialize radar
        updateRadarChart();

        // Watch for theme changes to re-render chart colors
        const observer = new MutationObserver(() => updateRadarChart());
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    }
  }

  // Register custom element
  if (!customElements.get('subject-radar')) {
    customElements.define('subject-radar', SubjectRadar);
  }
</script>
