---
import fs from 'node:fs';
import path from 'node:path';

// Load and parse the CSV data server-side
const csvPath = path.resolve('./src/blog/classes.csv');
const csvContent = fs.readFileSync(csvPath, 'utf-8');

// Parse the CSV
const rows = csvContent.trim().split('\n');
const headers = rows[0].split(',');

// Extract data, skipping header
const classesData = rows.slice(1).map(row => {
  // Simple CSV parser that handles quotes for commas
  let inQuotes = false;
  let currentField = '';
  const fields = [];
  
  for (let i = 0; i < row.length; i++) {
    const char = row[i];
    if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === ',' && !inQuotes) {
      fields.push(currentField);
      currentField = '';
    } else {
      currentField += char;
    }
  }
  fields.push(currentField);
  
  return {
    term: fields[0],
    subject: fields[1],
    course: fields[2],
    title: fields[3],
    units: parseFloat(fields[4]),
    usefulness: parseInt(fields[5] || '5', 10),
    enjoyment: parseInt(fields[6] || '5', 10),
    workload: parseInt(fields[7] || '5', 10),
    difficulty: parseInt(fields[8] || '5', 10),
    skipability: parseInt(fields[9] || '5', 10),
    id: `${fields[1]} ${fields[2]}`.trim()
  };
});
---

<course-radar data-classes={JSON.stringify(classesData)} class="block w-full">
  <div class="p-6 bg-light-base00 dark:bg-dark-base00 border border-light-base02 dark:border-dark-base02 transition-colors duration-200">
    <h3 class="text-xl font-bold text-light-base05 dark:text-white mb-6 transition-colors">Class Stats Radar (Select a Class)</h3>
    <div class="flex flex-col md:flex-row gap-8 items-center">
      <div class="w-full md:w-1/3">
        <select id="classSelector" class="w-full p-3 rounded-lg bg-light-base01 dark:bg-dark-base01 text-light-base05 dark:text-white border border-light-base02 dark:border-dark-base02 focus:outline-none focus:ring-2 focus:ring-light-base0B dark:focus:ring-dark-base0B transition-colors">
          {classesData.map(cls => (
            <option value={cls.id}>{cls.id} - {cls.title}</option>
          ))}
        </select>
        <div id="classDetails" class="mt-6 text-light-base04 dark:text-dark-base04 space-y-2 transition-colors">
          <!-- Details populated by JS -->
        </div>
      </div>
      <div class="relative w-full md:w-2/3 h-[400px]">
        <canvas id="radarChart"></canvas>
      </div>
    </div>
  </div>
</course-radar>

<script>
  import Chart from 'chart.js/auto';

  class CourseRadar extends HTMLElement {
    connectedCallback() {
      // Delay initialization slightly to ensure canvas elements are parsed
      requestAnimationFrame(() => {
        this.initCharts();
      });
    }

    initCharts() {
      const classesData = JSON.parse(this.dataset.classes);
      
      // --- RADAR CHART ---
      const radarCtx = this.querySelector('#radarChart');
      const selector = this.querySelector('#classSelector');
      const detailsContainer = this.querySelector('#classDetails');

      if (radarCtx && selector && detailsContainer) {
        let radarChart;
        let currentClassId = classesData.length > 0 ? classesData[0].id : null;

        const updateRadarChart = (classId) => {
          if (!classId) return;
          const cls = classesData.find(c => c.id === classId);
          if (!cls) return;

          // Update Details
          detailsContainer.innerHTML = `
            <p><strong class="text-light-base05 dark:text-white">Course:</strong> ${cls.id}</p>
            <p><strong class="text-light-base05 dark:text-white">Title:</strong> ${cls.title}</p>
            <p><strong class="text-light-base05 dark:text-white">Term:</strong> ${cls.term}</p>
            <p><strong class="text-light-base05 dark:text-white">Units:</strong> ${cls.units}</p>
          `;

          const isDark = document.documentElement.classList.contains('dark');
          // Oxocarbon Theme Accents
          const accentColor = isDark ? '#be95ff' : '#be95ff'; // base0E (Purple)
          const pointColor = isDark ? '#33b1ff' : '#0f62fe'; // base0B (Blue)
          const textColor = isDark ? '#dde1e6' : '#525252'; // base04 / base02 (Text)
          const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
          
          const radarData = {
            labels: ['Enjoyment', 'Usefulness', 'Workload', 'Difficulty', 'Skipability'],
            datasets: [{
              label: cls.id,
              data: [cls.enjoyment, cls.usefulness, cls.workload, cls.difficulty, cls.skipability],
              backgroundColor: 'rgba(190, 149, 255, 0.2)', // Purple transparent
              borderColor: accentColor,
              pointBackgroundColor: pointColor,
              pointBorderColor: isDark ? '#161616' : '#f2f4f8',
              pointHoverBackgroundColor: isDark ? '#161616' : '#f2f4f8',
              pointHoverBorderColor: pointColor,
              borderWidth: 2,
            }]
          };

          if (radarChart) {
            radarChart.data = radarData;
            radarChart.options.scales.r.angleLines.color = gridColor;
            radarChart.options.scales.r.grid.color = gridColor;
            radarChart.options.scales.r.pointLabels.color = textColor;
            radarChart.update();
          } else {
            radarChart = new Chart(radarCtx, {
              type: 'radar',
              data: radarData,
              options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                  r: {
                    angleLines: { color: gridColor },
                    grid: { color: gridColor },
                    pointLabels: { color: textColor, font: { size: 14 } },
                    min: 0,
                    max: 10,
                    ticks: { display: false, stepSize: 2 }
                  }
                },
                plugins: {
                  legend: { display: false },
                  tooltip: {
                    backgroundColor: isDark ? 'rgba(38, 38, 38, 0.95)' : 'rgba(255, 255, 255, 0.95)',
                    titleColor: isDark ? '#ffffff' : '#161616',
                    bodyColor: isDark ? '#dde1e6' : '#525252',
                    borderColor: gridColor,
                    borderWidth: 1,
                    padding: 12
                  }
                }
              }
            });
          }
        };

        // Initialize radar
        updateRadarChart(currentClassId);

        // Handle selection change
        selector.addEventListener('change', (e) => {
          currentClassId = e.target.value;
          updateRadarChart(currentClassId);
        });

        // Watch for theme changes to re-render chart colors
        const observer = new MutationObserver(() => {
          if (currentClassId) updateRadarChart(currentClassId);
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    }
  }

  // Register custom element
  if (!customElements.get('course-radar')) {
    customElements.define('course-radar', CourseRadar);
  }
</script>
